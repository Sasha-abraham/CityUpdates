<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0D1B2A">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="32dp"
        android:paddingTop="64dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Create Account"
            android:textSize="30sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:layout_marginBottom="4dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Join your city community"
            android:textSize="14sp"
            android:textColor="#7B9EBE"
            android:layout_marginBottom="36dp"/>

        <EditText
            android:id="@+id/etName"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:hint="Full Name"
            android:inputType="textPersonName"
            android:textColor="#FFFFFF"
            android:textColorHint="#557A95"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:background="@drawable/input_bg"
            android:layout_marginBottom="12dp"/>

        <EditText
            android:id="@+id/etEmail"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:hint="Email address"
            android:inputType="textEmailAddress"
            android:textColor="#FFFFFF"
            android:textColorHint="#557A95"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:background="@drawable/input_bg"
            android:layout_marginBottom="12dp"/>

        <EditText
            android:id="@+id/etPassword"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:hint="Password (min 6 characters)"
            android:inputType="textPassword"
            android:textColor="#FFFFFF"
            android:textColorHint="#557A95"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:background="@drawable/input_bg"
            android:layout_marginBottom="12dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Select your area"
            android:textSize="13sp"
            android:textColor="#7B9EBE"
            android:layout_marginBottom="6dp"/>

        <Spinner
            android:id="@+id/spinnerArea"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:background="@drawable/input_bg"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:layout_marginBottom="28dp"/>

        <Button
            android:id="@+id/btnRegister"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="Create Account"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#0D1B2A"
            android:backgroundTint="#4FC3F7"
            android:layout_marginBottom="12dp"/>

        <Button
            android:id="@+id/btnBackToLogin"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="Back to Login"
            android:textSize="16sp"
            android:textColor="#4FC3F7"
            android:backgroundTint="#1A2D3E"/>

    </LinearLayout>
</ScrollView>